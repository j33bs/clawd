# OpenClaw .gitattributes
# EOL normalization and drift prevention
# Generated: 2026-02-05

# Normalize line endings for text files
* text=auto eol=lf

# Explicit text files
*.md text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binary files - no normalization
*.sqlite binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary

# Diff settings for better readability
*.md diff=markdown
*.json diff=json

# Governance files — use "ours" merge strategy so cron commits on other branches
# cannot silently overwrite these files when branches diverge.
# Claude Code is the authoritative maintainer of these files on the governance branch.
workspace/governance/CONTRIBUTION_REGISTER.md merge=ours
workspace/governance/.section_count merge=ours

# LanceDB runtime state — never merge
workspace/store/lancedb_data/** merge=ours

# Local/private context should stay out of audit archives by default
MEMORY.md export-ignore
TOOLS.md export-ignore
USER.md export-ignore
memory export-ignore
memory/** export-ignore
PREFERENCE_PACKET.md export-ignore
workspace/source-ui/state export-ignore
workspace/source-ui/state/** export-ignore
workspace/state export-ignore
workspace/state/** export-ignore
workspace/artifacts export-ignore
workspace/knowledge_base/data/discord_messages.jsonl export-ignore
workspace/knowledge_base/data/discord_research_messages.jsonl export-ignore
workspace/knowledge_base/data/telegram_messages.jsonl export-ignore
workspace/knowledge_base/data/telegram_memory_ingest_state.json export-ignore
workspace/knowledge_base/data/user_inferences.jsonl export-ignore
workspace/knowledge_base/data/preference_profile.json export-ignore
workspace/artifacts/** export-ignore
