# OpenClaw environment variables
# Copy to .env and fill in values. Never commit .env.
#
# Sections: [Store API] [Embeddings] [Memory ext] [Governance] [Tailscale/Mesh]
#           [HiveMind] [Telegram] [Inference gates] [Paths]

# ── Store API (workspace/store/api.py) ──────────────────────────────────────
STORE_API_KEY=                    # Auth key for /rebuild and write endpoints. Leave empty = reads open.
STORE_PORT=8765                   # HTTP port for CorrespondenceStore API
STORE_HOST=0.0.0.0                # Bind address (use 127.0.0.1 to restrict to localhost)

# ── Embeddings (workspace/store/sync.py) ────────────────────────────────────
EMBED_MODEL=all-MiniLM-L6-v2     # Sentence-transformers model name
HF_HUB_OFFLINE=1                  # Set to 1 to prevent HF from phoning home (recommended)
OPENCLAW_COREML_EMBED=0           # Set to 1 to use CoreML embedding cmd (Apple Silicon)
OPENCLAW_COREML_EMBED_CMD=        # Shell command for CoreML embedding (if above is 1)

# ── Memory extension (workspace/memory_ext/) ────────────────────────────────
OPENCLAW_MEMORY_EXT=0             # Master gate. Set to 1 to enable all memory_ext modules.
OPENCLAW_QUIESCE=0                # Set to 1 to suppress memory_ext side-effects globally
OPENCLAW_ROOT=                    # Repo root override (default: auto-detected from __file__)

# ── Governance / paths ──────────────────────────────────────────────────────
CLAWD_GOV_OVERLAY_DIR=            # Optional overlay dir for governance doc sync
CLAWD_GOV_OVERLAY_SYNC=0          # Set to 1 to enable overlay sync on nightly build
CLAWD_PREFLIGHT_QUARANTINE_DIR=   # Dir for preflight-quarantined files
CLAWD_PREFLIGHT_SKIP_NPM_TESTS=0  # Set to 1 to skip npm tests in preflight
CLAWD_PREFLIGHT_SKIP_UNITTESTS=0  # Set to 1 to skip Python unit tests in preflight
OPENCLAW_CRON_JOBS_FILE=          # Path to cron jobs manifest (default: workspace/scripts/cron_jobs.json)
OPENCLAW_CRON_RUNS_DIR=           # Dir for cron run logs
OPENCLAW_EXTERNAL_MEMORY_FILE=    # Path to external memory JSONL (agents/c_lawd/memory.jsonl etc.)

# ── Tailscale / mesh ────────────────────────────────────────────────────────
OPENCLAW_TAILSCALE=0              # Set to 1 when running behind Tailscale (enables peer auth)
GATEWAY_URL=                      # Tailscale gateway base URL (e.g. http://100.x.x.x:8765)
GATEWAY_TOKEN=                    # Token for Tailscale gateway requests
ALLOWED_CHAT_IDS=                 # Comma-separated Telegram chat IDs allowed to message agents

# ── Telegram (scripts/dali_messenger.py) ────────────────────────────────────
TG_API_ID=                        # Telegram API ID (from my.telegram.org)
TG_API_HASH=                      # Telegram API hash
TG_PHONE=                         # Phone number for Telethon session
TELETHON_API_ID=                  # Alternative Telethon API ID env var
TELETHON_API_HASH=                # Alternative Telethon API hash env var

# ── Correspondence store client (workspace/memory/unified_query.js) ─────────
CORRESPONDENCE_STORE_BASE_URL=http://127.0.0.1:8765  # Base URL for unified_query.js adapters

# ── HiveMind feature flags ───────────────────────────────────────────────────
HIVEMIND_ENABLE_OLLAMA_EMBEDDINGS=0   # Use Ollama for HiveMind embeddings instead of default
HIVEMIND_OLLAMA_EMBED_URL=            # Ollama embed endpoint if above is 1
ENABLE_ACTIVE_INFERENCE=0             # Enable HiveMind active inference module
ENABLE_FALLBACK=1                     # Allow fallback routing in HiveMind peer graph

# ── Inference gates ──────────────────────────────────────────────────────────
OPENCLAW_SURPRISE_GATE=0          # Enable surprise-gated section filtering
OPENCLAW_OSCILLATORY_GATING=0     # Enable oscillatory gating on responses
OPENCLAW_COUNTERFACTUAL_REPLAY=0  # Enable counterfactual replay module
OPENCLAW_DREAM_PRUNE=0            # Enable dream-state pruning of memory
OPENCLAW_PEER_ANNEAL=0            # Enable peer annealing in HiveMind
OPENCLAW_TRAIL_VALENCE=0          # Enable trail valence scoring
OPENCLAW_ROUTER_PROPRIOCEPTION=0  # Enable proprioceptive routing layer
OPENCLAW_PAUSE_CHECK=0            # Enable pause-check before response emission
OPENCLAW_PAUSE_CHECK_TEST_MODE=0  # Pause check test mode (skips actual pause)
OPENCLAW_POLICY_STRICT=0          # Enforce strict policy routing (no fallback)
OPENCLAW_WITNESS_LEDGER=0         # Enable witness ledger for audit trail
OPENCLAW_ITC_LOOKBACK=20          # ITC pipeline lookback window (sections)

# ── Skill graph ──────────────────────────────────────────────────────────────
SKILL_GRAPH_ROOT=                 # Root dir for skill graph data (default: workspace/skill-graph)

# ── Event paths ──────────────────────────────────────────────────────────────
TACTI_CR_EVENTS_PATH=             # Path to TACTI(C)-R events log
OPENCLAW_ALLOWLIST_PATH=          # Path to allowlist for policy router
OPENCLAW_EPITOPE_CACHE=           # Path to semantic immune epitope cache

# ── Perf tuning ──────────────────────────────────────────────────────────────
MAX_LATENCY_MS=5000               # Max acceptable response latency (ms) for arousal gating
MAX_QUEUE_DEPTH=10                # Max queue depth before load shedding
