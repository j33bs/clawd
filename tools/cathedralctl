augment_status() {
  local target="$1"
  python3 -c '
from pathlib import Path
import json
import sys

env_path = Path(sys.argv[1])
target = sys.argv[2]
payload = json.load(sys.stdin)
current_profile = "unknown"
if env_path.exists():
    for line in env_path.read_text(encoding="utf-8").splitlines():
        if line.startswith("DALI_FISHTANK_MODE_PROFILE="):
            current_profile = line.split("=", 1)[1].strip() or "unknown"
            break
payload["profile_target"] = target
payload["profile_current"] = current_profile
print(json.dumps(payload, ensure_ascii=True, sort_keys=True))
' "$ENV_FILE" "$target"
}

EXTRA_ARGS=()
HAS_WAIT_FLAG=0
HAS_WAIT_TIMEOUT=0
for arg in "$@"; do
  case "$arg" in
    --wait-visible|--wait-hidden|--no-wait)
      HAS_WAIT_FLAG=1
      ;;
    --wait-timeout)
      HAS_WAIT_TIMEOUT=1
      ;;
  esac
done
if [[ "$ACTION" != "status" && "$HAS_WAIT_TIMEOUT" -eq 0 ]]; then
  EXTRA_ARGS+=(--wait-timeout 12)
fi
if [[ "$ACTION" == "on" && "$HAS_WAIT_FLAG" -eq 0 ]]; then
  if [[ "$MODE_TARGET" == "fishtank" ]]; then
    EXTRA_ARGS+=(--wait-visible)
  fi
fi
if [[ "$ACTION" == "off" && "$HAS_WAIT_FLAG" -eq 0 ]]; then
  EXTRA_ARGS+=(--wait-hidden)
fi

if [[ "$ACTION" != "status" ]]; then
  apply_profile "$MODE_TARGET"
  systemctl --user restart "$SERVICE_NAME"
  systemctl --user is-active --quiet "$SERVICE_NAME"
fi

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

export PYTHONPATH="$ROOT_DIR/workspace${PYTHONPATH:+:$PYTHONPATH}"
set +e
status_json="$(python3 -m cathedral.control_api "$ACTION" --source agent "${EXTRA_ARGS[@]}" "$@")"
status_rc=$?
set -e
printf '%s\n' "$status_json" | augment_status "$MODE_TARGET"
exit "$status_rc"
