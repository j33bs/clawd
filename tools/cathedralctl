#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="$HOME/.config/openclaw/dali-fishtank.env"
SERVICE_NAME="dali-fishtank.service"

usage() {
  echo "usage: $0 {fishtank|work} {on|off|auto|status} [--wait-visible|--wait-hidden] [--wait-timeout SEC]" >&2
  exit 1
}

MODE_TARGET="${1:-}"
[[ -n "$MODE_TARGET" ]] || usage
case "$MODE_TARGET" in
  fishtank|work) ;;
  *) usage ;;
esac
shift || true

ACTION="${1:-status}"
case "$ACTION" in
  on|off|auto|status) ;;
  *) usage ;;
esac
shift || true

