for line in lines:
    if "=" not in line or line.lstrip().startswith("#"):
        out.append(line)
        continue
    key, _ = line.split("=", 1)
    if key in settings:
        out.append(f"{key}={settings[key]}")
        seen.add(key)
    else:
        out.append(line)
for key, value in settings.items():
    if key not in seen:
        out.append(f"{key}={value}")
path.write_text("\n".join(out) + "\n", encoding="utf-8")
