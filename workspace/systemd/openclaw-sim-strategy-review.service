[Unit]
Description=OpenClaw periodic sim strategy review
After=network-online.target openclaw-itc-cycle.timer
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/src/clawd
ExecStart=/usr/bin/env bash %h/src/clawd/workspace/scripts/run_sim_strategy_review.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openclaw-sim-strategy-review

[Install]
WantedBy=default.target
