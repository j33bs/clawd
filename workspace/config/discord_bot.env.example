# OpenClaw Discord bot configuration
# Copy to: ~/.config/openclaw/discord-bot.env

OPENCLAW_DISCORD_BOT_TOKEN=
OPENCLAW_DISCORD_APP_ID=
OPENCLAW_DISCORD_GUILD_ID=
OPENCLAW_DISCORD_BOT_STATUS=watching Dali
OPENCLAW_DISCORD_ALLOWED_CHANNEL_IDS=
OPENCLAW_DISCORD_MUTATION_ROLE_IDS=
OPENCLAW_DISCORD_CHAT_CHANNEL_AGENT_MAP=
OPENCLAW_DISCORD_CHAT_THINKING=low
OPENCLAW_DISCORD_CHAT_TIMEOUT_SECONDS=180
OPENCLAW_DISCORD_MEMORY_CHANNEL_IDS=
OPENCLAW_DISCORD_MEMORY_AGENT_SCOPE=main
