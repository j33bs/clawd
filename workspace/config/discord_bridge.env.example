# OpenClaw Discord bridge configuration
# Copy to: ~/.config/openclaw/discord-bridge.env

# Safe default: only render/update local bridge status JSON.
OPENCLAW_DISCORD_BRIDGE_COMMAND=render-status
OPENCLAW_DISCORD_BRIDGE_FORCE=0

# Discord webhook URLs. Leave blank until you create the webhooks in Discord.
OPENCLAW_DISCORD_OPS_WEBHOOK=
OPENCLAW_DISCORD_SIM_WEBHOOK=
OPENCLAW_DISCORD_PROJECT_WEBHOOK=
