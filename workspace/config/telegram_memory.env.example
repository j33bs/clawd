# OpenClaw Telegram personal memory configuration
# Copy to: ~/.config/openclaw/telegram-memory.env

OPENCLAW_TELEGRAM_MEMORY_CHAT_IDS=
OPENCLAW_TELEGRAM_MEMORY_SELF_IDS=
OPENCLAW_TELEGRAM_MEMORY_SELF_NAMES=jeebs,j33bs,heath,heath yeager
OPENCLAW_TELEGRAM_MEMORY_ASSISTANT_NAMES=dali,c_lawd,openclaw
OPENCLAW_TELEGRAM_MEMORY_AGENT_SCOPE=main
OPENCLAW_TELEGRAM_MEMORY_BACKFILL=500
# Optional: override the shared Telethon session path if needed.
# OPENCLAW_TELEGRAM_MEMORY_SESSION_PATH=
