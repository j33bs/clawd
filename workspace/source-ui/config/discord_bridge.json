{
  "enabled": false,
  "dry_run": true,
  "channels": [
    {
      "id": "ops_status",
      "label": "#ops-status",
      "title": "Ops Status",
      "description": "Runtime health, assistant reachability, and active work summaries.",
      "delivery": "webhook",
      "enabled": true,
      "webhook_env": "OPENCLAW_DISCORD_OPS_WEBHOOK",
      "min_resend_minutes": 0,
      "schedule_timezone": "Australia/Brisbane",
      "schedule_local_times": ["09:00"],
      "report_mode": "scheduled_summary"
    },
    {
      "id": "sim_watch",
      "label": "#sim-watch",
      "title": "Sim Watch",
      "description": "Critical or fee-drag simulation summaries.",
      "delivery": "webhook",
      "enabled": true,
      "webhook_env": "OPENCLAW_DISCORD_SIM_WEBHOOK",
      "min_resend_minutes": 0,
      "schedule_timezone": "Australia/Brisbane",
      "schedule_local_times": ["09:00", "21:00"],
      "report_mode": "scheduled_summary"
    },
    {
      "id": "project_intake",
      "label": "#project-intake",
      "title": "Project Intake",
      "description": "Open project tasks and taskboard intake notifications.",
      "delivery": "webhook",
      "enabled": true,
      "auto_post": false,
      "webhook_env": "OPENCLAW_DISCORD_PROJECT_WEBHOOK",
      "min_resend_minutes": 180
    }
  ]
}
